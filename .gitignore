#################################################
# AI-ForgeStream
# Git Ignore Rules
#################################################

############################
# macOS
############################
.DS_Store
.AppleDouble
.LSOverride

############################
# Generated Media Outputs
############################
outputs/*
!outputs/.gitkeep

############################
# Temporary Media Files
############################
*.wav
*.aac
*.mp3
*.flac
*.m4a
*.ts
*.m3u8

############################
# Logs
############################
*.log

############################
# Temporary Files
############################
*.tmp
*.bak
*.swp

############################
# VS Code
############################
.vscode/

############################
# Python (Future AI Modules)
############################
__pycache__/
*.pyc
*.pyo
*.pyd

############################
# Virtual Environments
############################
venv/
.venv/

############################
# Environment Variables
############################
.env
.env.*

############################
# Terraform (Future Phase)
############################
.terraform/
*.tfstate
*.tfstate.*
terraform.tfvars
terraform.tfvars.json

############################
# Kubernetes Temp Files
############################
*.yaml.bak

############################
# IDE
############################
.idea/

############################
# OS Generated
############################
Thumbs.db

#################################################
# End
#################################################